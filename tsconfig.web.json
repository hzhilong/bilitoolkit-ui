{
  "compilerOptions": {
    "rootDir": "src",
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": [
      "ES2020", "dom"
    ],
    "strict": true,
    // 类型导入必须使用 type
    "verbatimModuleSyntax": true,
    // 强制每个文件都是独立可编译的模块
    "isolatedModules": true,
    // 跳过库的声明文件检查
    "skipLibCheck": true,
    // 文件名大小写一致检查
    "forceConsistentCasingInFileNames": true,
    // 允许导入 .ts/.tsx 文件扩展名
    "allowImportingTsExtensions": false,
    // 旧版 TS 装饰器语法
    "experimentalDecorators": false,
    // 生成 source map
    "sourceMap": true,
    // 禁用增量编译
    "incremental": false,
    // CommonJS 和 ES 模块互操作
    "esModuleInterop": true,
    // 启用导入 .json 文件
    "resolveJsonModule": true,
    "paths": {
      "@/*": [
        "./src/*"
      ]
    },
    // vue jsx
    "jsx": "preserve",
    "jsxFactory": "h",
    "jsxImportSource": "vue",
    "jsxFragmentFactory": "Fragment"
  },
  "include": [
    "./src/env.d.ts",
    "./auto-imports.d.ts",
    "./components.d.ts",
    "./src/global.d.ts",
    "./src/**/*",
    "./src/**/*.vue",
    "./src/**/*.d.ts",
    "./src/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    ".yalc",
    "yalc.lock"
  ]
}
