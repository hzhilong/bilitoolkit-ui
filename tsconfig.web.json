{
  "extends": "@vue/tsconfig/tsconfig.dom.json",
  "include": [
    "./src/env.d.ts",
    "./auto-imports.d.ts",
    "./components.d.ts",
    "./src/global.d.ts",
    "./src/**/*",
    "./src/**/*.vue",
    "./src/**/*.d.ts",
    "./src/**/*.ts"
  ],
  "exclude": [
    "./node_modules",
    ".yalc",
    "yalc.lock",
    "./src/**/__tests__/*"
  ],
  "compilerOptions": {
    "rootDir": "src",
    "strict": true,
    "allowImportingTsExtensions": true,
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "paths": {
      "@/*": [
        "./src/*"
      ]
    },
    // vue jsx
    "jsx": "preserve",
    "jsxFactory": "h",
    "jsxImportSource": "vue",
    "jsxFragmentFactory": "Fragment",
    // 包含的全局类型声明包
    // "types": ["vite/client"],
    // 包含哪些内置的API声明文件
    "lib": [
      "DOM",
      "ES2015"
    ]
    // https://www.typescriptlang.org/tsconfig/#verbatimModuleSyntax
    // 想关闭import显示类型，但vue好像推荐打开
    // https://cn.vuejs.org/guide/typescript/overview
    //    "verbatimModuleSyntax": false
  }
}
