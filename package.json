{
  "name": "bilitoolkit-ui",
  "version": "0.0.5",
  "private": false,
  "type": "module",
  "productName": "bilitoolkit-ui",
  "description": "『哔哩工具姬』的 UI 库",
  "author": "hzhilong",
  "keywords": [
    "BiliToolkit",
    "哔哩工具姬"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/hzhilong/bilitoolkit-ui"
  },
  "bugs": {
    "url": "https://github.com/hzhilong/bilitoolkit-ui/issues"
  },
  "homepage": "https://github.com/hzhilong/bilitoolkit-ui#readme",
  "license": "MIT",
  "packageManager": "pnpm@10.30.3",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "style": "./dist/index.css",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./common": {
      "types": "./dist/common.d.ts",
      "import": "./dist/common.js"
    },
    "./style.css": "./dist/bilitoolkit-ui.css",
    "./variables.scss": "./dist/styles/variables.scss",
    "./mixins.scss": "./dist/styles/mixins.scss",
    "./functions.scss": "./dist/styles/functions.scss"
  },
  "files": [
    "dist",
    "!dist/bundle-stats.*"
  ],
  "scripts": {
    "check": "vue-tsc -p tsconfig.web.json --noEmit",
    "lint": "eslint . --fix",
    "format": "prettier --write src/",
    "dev": "chcp 65001 && vite",
    "build": "vite build --mode library",
    "npm login": "npm login",
    "pnpm publish": "pnpm publish --access public"
  },
  "sideEffects": [
    "**/*.css",
    "**/*.scss",
    "**/*.less"
  ],
  "devDependencies": {
    "@tsconfig/node22": "^22.0.2",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^22.16.5",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vitejs/plugin-vue-jsx": "^5.0.1",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.6.0",
    "@vue/language-core": "^3.0.7",
    "eslint": "^9.31.0",
    "eslint-plugin-vue": "~10.3.0",
    "jiti": "^2.4.2",
    "npm-run-all2": "^8.0.4",
    "prettier": "3.6.2",
    "rollup-plugin-bundle-stats": "^4.21.3",
    "sass": "^1.92.1",
    "typescript": "^5.9.3",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^32.0.0",
    "vite": "^7.3.3",
    "vite-plugin-dts": "^4.5.4",
    "vite-plugin-static-copy": "^3.1.2",
    "vue-tsc": "^3.0.4",
    "remixicon": "^4.6.0"
  },
  "peerDependencies": {
    "@ybgnb/utils": "^0.2.8",
    "@ybgnb/bili-api": "workspace:^",
    "bilitoolkit-types": "workspace:^",
    "bilitoolkit-runtime": "workspace:^",
    "element-plus": "^2.13.7",
    "lodash-es": "^4.17.21",
    "pinia": "^3.0.3",
    "vue": "^3.5.34",
    "@vue/language-core": "^3.2.6"
  }
}
